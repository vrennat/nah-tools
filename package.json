{
	"name": "nah-tools",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"description": "Free, open-source browser tools that replace predatory SaaS. QR codes, PDFs, resumes, background removal, and more.",
	"author": "Tanner Vass",
	"homepage": "https://nah.tools",
	"repository": {
		"type": "git",
		"url": "https://github.com/vrennat/nah-tools.git"
	},
	"keywords": [
		"qr-code",
		"pdf",
		"resume-builder",
		"background-removal",
		"link-shortener",
		"invoice",
		"privacy",
		"open-source",
		"svelte",
		"cloudflare-workers"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "bun run build && wrangler deploy",
		"deploy:redirect": "cd redirect-worker && wrangler deploy",
		"db:migrate:local": "wrangler d1 execute nah-tools-db --local --file=migrations/0001_create_redirects.sql",
		"db:migrate:prod": "wrangler d1 execute nah-tools-db --file=migrations/0001_create_redirects.sql",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260329.1",
		"@sveltejs/adapter-cloudflare": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.0.0",
		"@types/bcryptjs": "^2.4.6",
		"@types/pdfmake": "^0.3.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.2",
		"wrangler": "^4.0.0"
	},
	"dependencies": {
		"@cantoo/pdf-lib": "^2.6.5",
		"@jsquash/avif": "^2.1.1",
		"@jsquash/jpeg": "^1.6.0",
		"@jsquash/jxl": "^1.3.0",
		"@jsquash/oxipng": "^2.3.0",
		"@jsquash/png": "^3.1.1",
		"@jsquash/webp": "^1.5.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"bcryptjs": "^2.4.3",
		"comlink": "^4.4.2",
		"compromise": "^14.15.0",
		"docx": "^9.6.1",
		"heic2any": "^0.0.4",
		"idb-keyval": "^6.2.2",
		"jspdf": "^2.5.2",
		"jszip": "^3.10.1",
		"mammoth": "^1.12.0",
		"onnxruntime-web": "^1.24.3",
		"pdfjs-dist": "^5.6.205",
		"pdfmake": "^0.3.7",
		"pica": "^9.0.1",
		"qr-code-styling": "^1.8.4"
	}
}
