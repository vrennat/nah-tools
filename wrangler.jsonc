{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "nah-tools",
	"compatibility_date": "2026-03-29",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": ".svelte-kit/cloudflare"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "nah-tools-db",
			"database_id": "TODO_REPLACE_WITH_D1_DATABASE_ID"
		}
	],
	"routes": [
		{
			"pattern": "nah.tools/*",
			"zone_name": "nah.tools"
		}
	]
}
